  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Glassmorphic Smooth Nav - Localhost</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=JetBrains+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --neon-green: #39ff14;\n            --dark-bg: #050505;\n            --glass-bg: rgba(20, 20, 20, 0.4);\n            --glass-border: rgba(255, 255, 255, 0.08);\n            --text-main: #ffffff;\n            --text-muted: #888888;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            background-color: var(--dark-bg);\n            font-family: 'Inter', sans-serif;\n            color: var(--text-main);\n            height: 200vh;\n            position: relative;\n            overflow-x: hidden;\n        }\n\n        /* Background Orbs to highlight Glassmorphism */\n        .bg-orb {\n            position: absolute;\n            border-radius: 50%;\n            filter: blur(80px);\n            z-index: -1;\n            animation: float 10s ease-in-out infinite alternate;\n        }\n        .orb-1 {\n            top: -50px;\n            left: 10%;\n            width: 300px;\n            height: 300px;\n            background: rgba(57, 255, 20, 0.15);\n        }\n        .orb-2 {\n            top: 100px;\n            right: 5%;\n            width: 250px;\n            height: 250px;\n            background: rgba(0, 150, 255, 0.1);\n            animation-delay: -5s;\n        }\n\n        @keyframes float {\n            0% { transform: translateY(0px); }\n            100% { transform: translateY(30px); }\n        }\n\n        /* Navbar Styles */\n        .navbar {\n            position: fixed;\n            top: 1.5rem;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 95%;\n            max-width: 1400px;\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            padding: 0.8rem 1.5rem;\n            background: var(--glass-bg);\n            backdrop-filter: blur(16px);\n            -webkit-backdrop-filter: blur(16px);\n            border: 1px solid var(--glass-border);\n            border-radius: 12px;\n            z-index: 1000;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\n            animation: slideDown 0.8s ease-out forwards;\n        }\n\n        @keyframes slideDown {\n            from {\n                top: -5rem;\n                opacity: 0;\n            }\n            to {\n                top: 1.5rem;\n                opacity: 1;\n            }\n        }\n\n        .navbar:hover {\n            background: rgba(30, 30, 30, 0.5);\n            border-color: rgba(255, 255, 255, 0.15);\n        }\n\n        /* Logo */\n        .nav-logo {\n            display: flex;\n            align-items: center;\n            cursor: pointer;\n            transition: transform 0.3s ease;\n        }\n        .nav-logo:hover {\n            transform: scale(1.05) rotate(5deg);\n        }\n        .nav-logo svg {\n            width: 24px;\n            height: 24px;\n            fill: var(--text-main);\n        }\n\n        /* Navigation Links */\n        .nav-links {\n            display: flex;\n            list-style: none;\n            gap: 2.5rem;\n        }\n\n        .nav-links li {\n            position: relative;\n        }\n\n        .nav-links a {\n            text-decoration: none;\n            color: var(--text-main);\n            font-size: 0.75rem;\n            font-weight: 600;\n            letter-spacing: 1.5px;\n            text-transform: uppercase;\n            transition: color 0.3s ease;\n            padding: 0.5rem 0;\n        }\n\n        /* Underline Animation */\n        .nav-links a::after {\n            content: '';\n            position: absolute;\n            bottom: -4px;\n            left: 0;\n            width: 0%;\n            height: 2px;\n            background-color: var(--neon-green);\n            transition: width 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\n            box-shadow: 0 0 8px var(--neon-green);\n        }\n\n        .nav-links a:hover {\n            color: var(--neon-green);\n        }\n\n        .nav-links a:hover::after {\n            width: 100%;\n        }\n\n        /* Right Actions */\n        .nav-actions {\n            display: flex;\n            align-items: center;\n            gap: 1rem;\n        }\n\n        /* Search Container */\n        .search-container {\n            display: flex;\n            align-items: center;\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(57, 255, 20, 0.3);\n            border-radius: 4px;\n            padding: 0.4rem 0.8rem;\n            transition: all 0.3s ease;\n        }\n\n        .search-container:focus-within {\n            border-color: var(--neon-green);\n            box-shadow: 0 0 10px rgba(57, 255, 20, 0.2);\n            background: rgba(0, 0, 0, 0.6);\n        }\n\n        .prompt-icon {\n            color: var(--neon-green);\n            font-family: 'JetBrains Mono', monospace;\n            font-size: 0.8rem;\n            margin-right: 0.5rem;\n        }\n\n        .search-input {\n            background: transparent;\n            border: none;\n            outline: none;\n            color: var(--text-main);\n            font-family: 'JetBrains Mono', monospace;\n            font-size: 0.75rem;\n            width: 120px;\n            transition: width 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\n        }\n\n        .search-input::placeholder {\n            color: var(--text-muted);\n        }\n\n        .search-input:focus {\n            width: 180px;\n        }\n\n        /* Initialize Button */\n        .init-btn {\n            background-color: var(--neon-green);\n            color: #000;\n            border: none;\n            padding: 0.5rem 1.2rem;\n            font-size: 0.75rem;\n            font-weight: 700;\n            letter-spacing: 1px;\n            text-transform: uppercase;\n            cursor: pointer;\n            border-radius: 4px;\n            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\n            box-shadow: 0 0 10px rgba(57, 255, 20, 0.1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .init-btn::before {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 300%;\n            height: 300%;\n            background: rgba(255,255,255,0.2);\n            transform: translate(-50%, -50%) rotate(45deg) translateY(100%);\n            transition: transform 0.6s ease;\n        }\n\n        .init-btn:hover::before {\n            transform: translate(-50%, -50%) rotate(45deg) translateY(-100%);\n        }\n\n        .init-btn:hover {\n            background-color: #4fff26;\n            box-shadow: 0 0 20px rgba(57, 255, 20, 0.6), 0 0 40px rgba(57, 255, 20, 0.2);\n            transform: translateY(-2px);\n        }\n\n        .init-btn:active {\n            transform: translateY(0);\n            box-shadow: 0 0 10px rgba(57, 255, 20, 0.4);\n        }\n\n        /* Responsive */\n        @media (max-width: 900px) {\n            .nav-links { display: none; }\n            .search-input { width: 80px; }\n            .search-input:focus { width: 120px; }\n        }\n    </style>\n</head>\n<body>\n\n    <!-- Background elements for visual context -->\n    <div class=\"bg-orb orb-1\"></div>\n    <div class=\"bg-orb orb-2\"></div>\n\n    <!-- Main Navigation Bar -->\n    <nav class=\"navbar\">\n        <div class=\"nav-logo\">\n            <!-- Abstract Geometric Logo -->\n            <svg viewBox=\"0 0 24 24\">\n                <path d=\"M12 2L2 22h20L12 2zm0 3.8l7.5 15H4.5L12 5.8z\"/>\n                <circle cx=\"12\" cy=\"15\" r=\"2\" fill=\"#39ff14\"/>\n            </svg>\n        </div>\n\n        <ul class=\"nav-links\">\n            <li><a href=\"#explore\">Explore Services</a></li>\n            <li><a href=\"#works\">How It Works</a></li>\n            <li><a href=\"#pricing\">Pricing</a></li>\n            <li><a href=\"#blogs\">Blogs</a></li>\n        </ul>\n\n        <div class=\"nav-actions\">\n            <div class=\"search-container\">\n                <span class=\"prompt-icon\">>_</span>\n                <input type=\"text\" class=\"search-input\" placeholder=\"Query system...\">\n            </div>\n            <button class=\"init-btn\" onclick=\"alert('System Initialized Locally!')\">Initialize</button>\n        </div>\n    </nav>\n\n    <script>\n        // Optional: Add scroll effect to navbar on localhost\n        window.addEventListener('scroll', () => {\n            const nav = document.querySelector('.navbar');\n            if (window.scrollY > 50) {\n                nav.style.background = 'rgba(10, 10, 10, 0.75)';\n                nav.style.boxShadow = '0 10px 40px rgba(0, 0, 0, 0.8)';\n            } else {\n                nav.style.background = 'var(--glass-bg)';\n                nav.style.boxShadow = '0 8px 32px rgba(0, 0, 0, 0.3)';\n            }\n        });\n    </script>\n</body>\n</html>"
}
